{
  "name": "@clipkit/runtime",
  "version": "1.0.0",
  "description": "Clipkit runtime — WebGPU compositor and WebCodecs encoder. Consumes the Clipkit schema, produces frames or MP4.",
  "license": "SEE LICENSE IN ./LICENSE",
  "repository": { "type": "git", "url": "git+https://github.com/clipkit-video/clipkit.git", "directory": "packages/runtime" },
  "homepage": "https://clipkit.dev",
  "bugs": "https://github.com/clipkit-video/clipkit/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./renderer": {
      "import": "./dist/renderer/index.js",
      "types": "./dist/renderer/index.d.ts"
    },
    "./encoder": {
      "import": "./dist/encoder/index.js",
      "types": "./dist/encoder/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@clipkit/protocol": "^1.0.0",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^1.5.0"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.65",
    "typescript": "^5.7.3"
  }
}

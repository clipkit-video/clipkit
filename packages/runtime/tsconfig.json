{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "composite": false,
    "types": ["@webgpu/types"],
    // Loosened for the ported renderer. The upstream code predates these
    // checks and re-enabling them is a post-port hardening pass.
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
